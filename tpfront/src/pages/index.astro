---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
    <div class="inicio">
        <h1>Oraculo de dados</h1>
        <p class="descripcion">Tirá los dados y dejá que el destino decida por vos</p>
        <a href="/inicio" class="btn-comenzar">🎲 Comenzar</a>
    </div>
</div>
		</main>
	</body>
</html>
<style>
main {
    margin: 0;
    padding: 0;
}

.inicio {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    height: 80vh;
    gap: 1.5rem;
    padding: 2rem;
    width: 100%;    
	box-sizing: border-box;
}

.inicio h1 {
    font-size: 3.5rem;
    background: linear-gradient(135deg, #c084fc, #7b2d8b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin: 0;
}

.descripcion {
    font-size: 1.2rem;
    color: #888;
    max-width: 450px;
    margin: 0;
}

.btn-comenzar {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: linear-gradient(135deg, #7b2d8b, #4a1060);
    color: white;
    text-decoration: none;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: bold;
    box-shadow: 0 4px 15px rgba(123, 45, 139, 0.5);
    transition: all 0.3s;
}

.btn-comenzar:hover {
    background: linear-gradient(135deg, #9b3dab, #6a2080);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(123, 45, 139, 0.7);
    color: white;
}
  </style>
  
